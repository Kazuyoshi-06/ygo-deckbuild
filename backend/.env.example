# Application
APP_NAME=YGO Deck Intelligence
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ygo_deckbuild

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./media

# For S3-compatible storage (production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_ENDPOINT=
# AWS_S3_REGION=

# External APIs
YGOPRO_API_BASE=https://db.ygoprodeck.com/api/v7
# Passer à false si les certificats SSL locaux posent problème (dev only)
VERIFY_SSL=true

# Optional: single URL or local path to an EdoPro cards.cdb for pre-release card sync
# YGOPRO_CDB_URL=C:/GAMES/ProjectIgnis/expansions/cards.cdb

# Semicolon-separated list of local .cdb paths (takes priority over YGOPRO_CDB_URL)
# Use ; as separator — colon is reserved in Windows paths (C:\...)
# YGOPRO_CDB_PATHS=C:/EdoPro/expansions/cards.cdb;C:/EdoPro/repos/ygopro-pre-release.cdb

# Auto-trigger CDB sync when the backend starts (opt-in, default false)
# Requires YGOPRO_CDB_PATHS or YGOPRO_CDB_URL to be set
# AUTO_SYNC_CDB_ON_STARTUP=false

# CORS (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# Auth (single-user mode)
# Set AUTH_ENABLED=false to disable auth entirely (dev/local use)
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Alerting — POST to this URL when a sync fails (Slack / Discord / generic webhook)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
